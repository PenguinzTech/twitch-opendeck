        {
            "UUID": "io.pngz.twitch.createclip",
            "Name": "Create Clip",
            "Icon": "actions/create_clip",
            "Tooltip": "Create a clip of the last 90 seconds",
            "PropertyInspectorPath": "pi/simple.html",
            "Controllers": [
                "Keypad"
            ],
            "States": [
                {
                    "Image": "actions/create_clip"
                }
