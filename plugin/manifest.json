{
    "Name": "Twitch Stream Control",
    "Description": "Control your Twitch stream directly from your deck. Toggle chat modes, run ads, create clips and markers, check viewer count, and more.",
    "Author": "penguin",
    "Version": "0.1.0",
    "Category": "Twitch",
    "Icon": "icon",
    "CategoryIcon": "icon",
    "OS": [
        {
            "Platform": "windows"
        },
        {
            "Platform": "mac"
        },
        {
            "Platform": "linux"
        }
    ],
    "CodePaths": {
        "x86_64-pc-windows-msvc": "twitch-opendeck-x86_64-pc-windows-msvc.exe",
        "x86_64-apple-darwin": "twitch-opendeck-x86_64-apple-darwin",
        "aarch64-apple-darwin": "twitch-opendeck-aarch64-apple-darwin",
        "x86_64-unknown-linux-gnu": "twitch-opendeck-x86_64-unknown-linux-gnu",
        "aarch64-unknown-linux-gnu": "twitch-opendeck-aarch64-unknown-linux-gnu"
    },
    "CodePathWin": "twitch-opendeck-x86_64-pc-windows-msvc.exe",
    "CodePathMac": "twitch-opendeck-x86_64-apple-darwin",
    "CodePathLin": "twitch-opendeck-x86_64-unknown-linux-gnu",
    "PropertyInspectorPath": "pi/simple.html",
    "Actions": [
        {
            "UUID": "io.pngz.twitch.chatmessage",
            "Name": "Chat Message",
            "Icon": "actions/chat_message",
            "Tooltip": "Send a preset message to your Twitch chat",
            "PropertyInspectorPath": "pi/auth.html",
            "Controllers": [
                "Keypad"
            ],
            "States": [
                {
                    "Image": "actions/chat_message"
                }
            ]
        },
        {
            "UUID": "io.pngz.twitch.clearchat",
            "Name": "Clear Chat",
            "Icon": "actions/clear_chat",
            "Tooltip": "Clear all messages from your chat",
            "PropertyInspectorPath": "pi/simple.html",
            "Controllers": [
                "Keypad"
            ],
            "States": [
                {
                    "Image": "actions/clear_chat"
                }
            ]
        },
        {
            "UUID": "io.pngz.twitch.emotechat",
            "Name": "Emote Only Chat",
            "Icon": "actions/emote_chat_0",
            "Tooltip": "Toggle emote-only chat mode",
            "PropertyInspectorPath": "pi/simple.html",
            "Controllers": [
                "Keypad"
            ],
            "DisableAutomaticStates": true,
            "States": [
                {
                    "Image": "actions/emote_chat_0",
                    "Name": "Activate"
                },
                {
                    "Image": "actions/emote_chat_1",
                    "Name": "Deactivate"
                }
            ]
        },
        {
            "UUID": "io.pngz.twitch.followerschat",
            "Name": "Followers Only Chat",
            "Icon": "actions/follower_chat_0",
