                "Keypad"
            ],
            "DisableAutomaticStates": true,
            "States": [
                {
                    "Image": "actions/slow_chat_0",
                    "Name": "Activate"
                },
                {
                    "Image": "actions/slow_chat_1",
                    "Name": "Deactivate"
                }
            ]
        },
        {
            "UUID": "io.pngz.twitch.playad",
            "Name": "Play Ad",
            "Icon": "actions/play_ad",
