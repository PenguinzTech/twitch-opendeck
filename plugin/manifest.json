            "Controllers": [
                "Keypad"
            ],
            "DisableAutomaticStates": true,
            "States": [
                {
                    "Image": "actions/follower_chat_0",
                    "Name": "Activate"
                },
                {
                    "Image": "actions/follower_chat_1",
                    "Name": "Deactivate"
                }
            ]
        },
        {
            "UUID": "io.pngz.twitch.subchat",
            "Name": "Subscribers Only Chat",
            "Icon": "actions/sub_chat_0",
            "Tooltip": "Toggle subscriber-only chat mode",
            "PropertyInspectorPath": "pi/simple.html",
            "Controllers": [
                "Keypad"
            ],
            "DisableAutomaticStates": true,
            "States": [
                {
                    "Image": "actions/sub_chat_0",
                    "Name": "Activate"
                },
                {
                    "Image": "actions/sub_chat_1",
                    "Name": "Deactivate"
                }
            ]
