            "PropertyInspectorPath": "pi/simple.html",
            "Controllers": [
                "Keypad"
            ],
            "DisableAutomaticStates": true,
            "States": [
                {
                    "Image": "actions/shield_mode_0",
                    "Name": "Activate"
                },
                {
                    "Image": "actions/shield_mode_1",
                    "Name": "Deactivate"
                }
            ]
        }
